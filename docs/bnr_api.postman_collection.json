{
  "info": {
    "name": "BNR Compliance Portal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:3000/api" },
    { "key": "access_token",    "value": "" },
    { "key": "refresh_token",   "value": "" },
    { "key": "application_id",  "value": "" },
    { "key": "document_id",     "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (applicant)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newapplicant@rtn.rw\",\n  \"password\": \"Pass@1234\",\n  \"full_name\": \"Test Applicant\",\n  \"role\": \"APPLICANT\",\n  \"organization\": \"Test Corp\"\n}"
            }
          }
        },
        {
          "name": "Login as Applicant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"applicant@rtn.rw\",\n  \"password\": \"Applicant@2026\"\n}"
            }
          }
        },
        {
          "name": "Login as Reviewer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reviewer@bnr.rw\",\n  \"password\": \"Reviewer@2026\"\n}"
            }
          }
        },
        {
          "name": "Login as Approver",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"approver@bnr.rw\",\n  \"password\": \"Approver@2026\"\n}"
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bnr.rw\",\n  \"password\": \"Admin@2026\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('access_token', body.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.application && body.application.id) {",
                  "  pm.collectionVariables.set('application_id', body.application.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institution_name\": \"Test Bank Ltd\",\n  \"institution_type\": \"Commercial Bank\",\n  \"license_type\": \"Full Banking License\",\n  \"registration_number\": \"BNR-2026-001\",\n  \"contact_email\": \"info@testbank.rw\",\n  \"contact_phone\": \"+250788000000\"\n}"
            }
          }
        },
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications"
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}"
          }
        },
        {
          "name": "Update Application",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/applications/{{application_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institution_name\": \"Updated Test Bank Ltd\",\n  \"contact_email\": \"updated@testbank.rw\"\n}"
            }
          }
        },
        {
          "name": "Submit Application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/submit"
          }
        },
        {
          "name": "Start Review",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/start-review"
          }
        },
        {
          "name": "Request Additional Info",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/applications/{{application_id}}/request-info",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Please provide a clearer copy of the Certificate of Incorporation.\"\n}"
            }
          }
        },
        {
          "name": "Resubmit Application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/resubmit"
          }
        },
        {
          "name": "Complete Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/applications/{{application_id}}/complete-review",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"review_notes\": \"All submitted materials are complete and consistent with BNR licensing requirements.\"\n}"
            }
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/approve"
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/applications/{{application_id}}/reject",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Capital adequacy documentation does not meet the minimum threshold required under BNR licensing guidelines.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Get Document Types",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/document-types"
          }
        },
        {
          "name": "Upload Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.document && body.document.id) {",
                  "  pm.collectionVariables.set('document_id', body.document.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/documents",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "document_type",
                  "value": "Certificate of Incorporation",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        },
        {
          "name": "List Application Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/documents"
          }
        },
        {
          "name": "Download Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/documents/{{document_id}}/download"
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "Application Audit Trail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/applications/{{application_id}}/audit"
          }
        },
        {
          "name": "System Audit Log (Admin only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/audit"
          }
        }
      ]
    }
  ]
}
